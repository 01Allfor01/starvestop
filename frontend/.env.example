# 백엔드 API URL (로컬 개발)
NEXT_PUBLIC_API_URL=http://localhost:8080

# 백엔드 API URL (프로덕션 - 배포 시 변경)
# NEXT_PUBLIC_API_URL=https://api.starvestop.com

# WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# 카카오 로그인
NEXT_PUBLIC_KAKAO_CLIENT_ID=카카오_클라이언트_ID를_여기에_입력
NEXT_PUBLIC_KAKAO_REDIRECT_URI=http://localhost:3000

# 토스페이먼츠
NEXT_PUBLIC_TOSS_CLIENT_KEY=토스페이먼츠_클라이언트_키를_여기에_입력

# 카카오 지도 (추후 필요 시)
# NEXT_PUBLIC_KAKAO_MAP_KEY=카카오_지도_API_키를_여기에_입력
